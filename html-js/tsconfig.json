{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Preserve",
    "rootDir": "src",
    "outDir": "../src/main/resources",
    "strict": true,
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": [
    "src/html/js/debug_constants.ts",
    "src/html/js/debugconstants.ts"
  ]
}
